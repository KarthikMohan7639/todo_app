<Window x:Class="TodoClient.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Todo List Client" Height="600" Width="800">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <!-- Header -->
        <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="10">
            <TextBlock Text="Todo List Application" FontSize="20" FontWeight="Bold" VerticalAlignment="Center"/>
            <TextBlock x:Name="StatusText" Text="Disconnected" Margin="20,0,0,0" VerticalAlignment="Center" Foreground="Red"/>
        </StackPanel>
        
        <!-- Todo List -->
        <Border Grid.Row="1" BorderBrush="Gray" BorderThickness="1" Margin="10">
            <ListView x:Name="TodoListView" SelectionMode="Single">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Status" Width="80">
                            <GridViewColumn.CellTemplate>
                                <DataTemplate>
                                    <CheckBox IsChecked="{Binding IsCompleted}" 
                                              Click="TodoItem_StatusChanged"
                                              Tag="{Binding Id}"/>
                                </DataTemplate>
                            </GridViewColumn.CellTemplate>
                        </GridViewColumn>
                        <GridViewColumn Header="Description" Width="400" DisplayMemberBinding="{Binding Description}"/>
                        <GridViewColumn Header="ID" Width="50" DisplayMemberBinding="{Binding Id}"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </Border>
        
        <!-- Add New Todo -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="10">
            <TextBox x:Name="NewTodoTextBox" Width="300" Height="25" VerticalAlignment="Center"
                     KeyDown="NewTodoTextBox_KeyDown" Text="{Binding NewTodoText, UpdateSourceTrigger=PropertyChanged}"/>
            <Button x:Name="AddTodoButton" Content="Add Todo" Width="100" Height="30" Margin="10,0,0,0"
                    Click="AddTodoButton_Click"/>
            <Button x:Name="RefreshButton" Content="Refresh" Width="80" Height="30" Margin="10,0,0,0"
                    Click="RefreshButton_Click"/>
        </StackPanel>
    </Grid>
</Window>